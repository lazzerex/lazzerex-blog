---
import { ChevronDown } from 'lucide-astro';
---

<header class="top-bar" aria-label="Top bar">
  <div class="top-bar-left">
    <div class="avatar-chip" aria-hidden="true">
      <img src="/images/hardware.jfif" alt="" width="28" height="28" />
    </div>
    <div class="author-meta">
      <p class="author-name">Lazzerex</p>
      <span class="section-dropdown">Explore <ChevronDown size={14} strokeWidth={1.5} /></span>
    </div>
  </div>

  <div class="top-bar-right">
    <span class="role-label">Backend, Systems & Web Development</span>
  </div>
</header>
