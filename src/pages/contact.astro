---
import DesktopShellLayout from "../layouts/DesktopShellLayout.astro";
---

<DesktopShellLayout
  title="Lazzerex | Contact"
  description="Contact Lazzerex for collaboration, feedback, or technical discussion."
  currentPath="/contact"
>
  <section class="content-window">
    <p class="window-path" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="path-muted">→</span>
      <span>Contact</span>
    </p>

    <article class="detail-article">
      <h1>Contact</h1>
      <p>
        If you want to discuss engineering topics, project collaboration, or article feedback, use one of the channels below.
      </p>

      <ul class="contact-list" aria-label="Contact channels">
        <li class="contact-item">
          <h2>Email</h2>
          <p>
            <a href="mailto:nambinh236@gmail.com">nambinh236@gmail.com</a>
          </p>
        </li>
        <li class="contact-item">
          <h2>GitHub</h2>
          <p>
            <a href="https://github.com/lazzerex" target="_blank" rel="noopener noreferrer">
              github.com/lazzerex
            </a>
          </p>
        </li>
      </ul>
    </article>
  </section>
</DesktopShellLayout>
